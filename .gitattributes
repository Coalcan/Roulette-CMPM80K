# Normalize line endings for all text files that git auto-detects
* text=auto eol=lf

*.gd        text eol=lf
*.cs        text eol=lf
*.tres      text eol=lf
*.tscn      text eol=lf
*.cfg       text eol=lf
*.import    text eol=lf
*.godot     text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.svg       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

